<launch>
  <!-- Static transforms for frame compatibility -->
  <node pkg="tf" type="static_transform_publisher" name="odom_to_world"
        args="0 0 0 0 0 0 odom world 100" />

  <node pkg="tf" type="static_transform_publisher" name="odom_to_map"
        args="0 0 0 0 0 0 odom map 100" />

  <!-- Map configuration -->
  <arg name="map_name" value="garage" />
  <arg name="config_file" default="$(arg map_name).yaml" />

  <!-- Sensor publish rate control -->
  <arg name="odom_publish_rate" default="10.0" />
  <arg name="sensing_rate" default="10.0" />

  <!-- Odometry topic (configure based on your odometry source) -->
  <arg name="odom_topic" default="/quad_0/lidar_slam/odom" />

  <!-- Reactive local avoidance (SIM 전용). true=켬. 실기 EPIC 은 real_flight.launch 를 쓰므로 영향 없음. -->
  <arg name="enable_avoidance" default="true" />

  <!-- Evaluation parameters -->
  <arg name="eval_output_dir" default="$(find epic_planner)/experiments" />
  <arg name="eval_auto_shutdown" default="false" />

  <!-- Trajectory/Waypoint server -->
  <node pkg="waypoint_generator" name="waypoint_generator" type="waypoint_generator" output="screen">
    <remap from="~odom" to="$(arg odom_topic)" />
    <remap from="~goal" to="/move_base_simple/goal" />
    <remap from="~traj_start_trigger" to="/traj_start_trigger" />
    <param name="waypoint_type" value="point" />
  </node>

  <!-- Odometry visualization -->
  <node pkg="odom_visualization" name="quad0_odom_visualization" type="odom_visualization" output="screen">
    <remap from="~odom" to="$(arg odom_topic)" />
    <param name="init_x" value="0.0" />
    <param name="init_y" value="0.0" />
    <param name="init_z" value="1.0" />
    <param name="color/a" value="1.0" />
    <param name="color/r" value="0.0" />
    <param name="color/g" value="1.0" />
    <param name="color/b" value="1.0" />
    <param name="covariance_scale" value="100.0" />
    <param name="robot_scale" value="1.0" />
    <param name="quadrotor_name" value="quad0" />
    <param name="drone_id" value="0" />
    <param name="mesh_resource" value="package://odom_visualization/meshes/yunque.dae" />
  </node>

  <!-- EPIC exploration algorithm -->
  <include file="$(find epic_planner)/launch/algorithm.xml">
    <arg name="config_file" value="$(arg config_file)" />
  </include>

  <!-- Trajectory server: MINCO 궤적/호버를 /position_cmd 로 발행.
       /position_cmd -> /planning/pos_cmd(cascadePID) 라우팅은 아래 enable_avoidance 그룹이 담당한다
       (회피 ON: avoid_mux MUX / OFF: 단순 relay). traj_server 자체엔 remap 하지 않는다. -->
  <node pkg="plan_manage" name="traj_server" type="traj_server" output="screen" />

  <!-- ===== Reactive local avoidance (SIM 전용, enable_avoidance 로 on/off) =====
       실기는 real_flight.launch 가 px4_ctrl_bridge MUX + 실제 /livox/lidar 로 처리하므로
       이 블록을 두지 않는다(= 실기 EPIC 구동 시 자동으로 꺼짐). -->
  <group if="$(arg enable_avoidance)">
    <!-- 1) LiDAR 브릿지: MARSIM cloud(world, PointCloud2) -> body 변환 + livox CustomMsg(/livox/lidar) -->
    <node pkg="local_avoidance" type="pc2_to_livox.py" name="pc2_to_livox" output="screen">
      <param name="cloud_topic" value="/quad0_pcl_render_node/cloud" />
      <param name="odom_topic"  value="$(arg odom_topic)" />
      <param name="livox_topic" value="/livox/lidar" />
      <param name="max_range"   value="20.0" />
      <param name="max_points"  value="4000" />
    </node>

    <!-- 2) 반사 국소회피 노드 (실기와 동일 노드). /target_avoidance + /FSM_flag_avoidance 발행 -->
    <include file="$(find local_avoidance)/launch/local_avoidance.launch">
      <arg name="lidar_topic" value="/livox/lidar" />
      <arg name="odom_topic"  value="$(arg odom_topic)" />
    </include>

    <!-- 3) MUX (실기 px4_ctrl_bridge MUX 대역): flag=1이면 escape, 아니면 EPIC -> /planning/pos_cmd -->
    <node pkg="local_avoidance" type="avoid_mux.py" name="avoid_mux" output="screen">
      <param name="enable_avoidance"  value="true" />
      <param name="epic_topic"        value="/position_cmd" />
      <param name="out_topic"         value="/planning/pos_cmd" />
      <param name="flag_timeout"      value="0.5" />
      <param name="avoid_cmd_timeout" value="0.3" />
    </node>
  </group>

  <group unless="$(arg enable_avoidance)">
    <!-- 회피 OFF: EPIC 명령(/position_cmd: 호버+궤적)을 그대로 cascadePID 로 relay -->
    <node pkg="topic_tools" type="relay" name="epic_cmd_relay"
          args="/position_cmd /planning/pos_cmd" output="screen" />
  </group>

  <!-- Exploration evaluation metrics -->
  <node pkg="epic_planner" name="exploration_evaluator" type="evaluate_exploration.py" output="screen">
    <param name="odom_topic" value="$(arg odom_topic)" />
    <param name="position_cmd_topic" value="/planning/pos_cmd" />
    <param name="pcd_path" value="$(find map_generator)/resource/garage.pcd" />
    <param name="cell_size" value="0.4" />
    <param name="map_min_x" value="-10.0" />
    <param name="map_min_y" value="-6.0" />
    <param name="map_min_z" value="-0.2" />
    <param name="map_max_x" value="182.0" />
    <param name="map_max_y" value="150.2" />
    <param name="map_max_z" value="3.8" />
    <param name="output_dir" value="$(arg eval_output_dir)" />
    <param name="auto_shutdown" value="$(arg eval_auto_shutdown)" />
  </node>

  <!-- Simulation environment (garage map with drone) -->
  <include file="$(find mars_drone_sim)/launch/garage.launch">
    <arg name="sensing_horizon" value="60.0" />
    <!-- odom_publish_rate / sensing_rate 는 MARSIM 런치 체인이 arg로 받지 않음
         (single_drone_with_fuel.xml 에서 sensing_rate 가 param 으로 하드코딩됨).
         전달하면 roslaunch가 "unused args" 에러를 내므로 넘기지 않는다. -->
  </include>

  <!-- RViz visualization -->
  <include file="$(find epic_planner)/launch/rviz.launch" />
</launch>